<Page x:Class="Urbanflow.src.frontend.pages.OptimizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Urbanflow.src.frontend.pages"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:util="clr-namespace:Urbanflow.src.backend.models.util"
      mc:Ignorable="d" 
      Background="White"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="OptimizationPage">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/src/frontend/resources/Buttons.xaml"/>
                <ResourceDictionary Source="/src/frontend/resources/Colors.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <util:LogLevelToBrushConverter x:Key="LogLevelToBrushConverter"/>

        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ==================== LEFT PANEL ==================== -->
        <Border Grid.Column="0"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,1,0"
                Padding="24"
                >
            <DockPanel LastChildFill="True">
                <!-- Bottom Buttons -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,24,0,0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Uid="btn_SaveConfig"
                            x:Name="btn_SaveConfig"
                            Content="Beállítások mentése"
                            Style="{StaticResource GreyButton}"
                            Width="140"
                            Height="30"
                            Click="btn_SaveConfig_Click"
                            />
                    <Button x:Uid="btn_RunGA"
                            x:Name="btn_RunGA"
                            Content="Optimalizálás futtatása"
                            Style="{StaticResource AccentGreenButton}"
                            Height="30"
                            Width="140"
                            Margin="10,0,0,0"
                            Click="btn_RunGA_Click"/>
                </StackPanel>

                <!-- Main Settings Content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,12">

                        <!-- Page Heading -->
                        <StackPanel Margin="0,0,0,24">
                            <TextBlock Text="Optimalizációs beállítások"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#1E1E1E"/>
                            <TextBlock Text="Konfigurálja az optimalizálási folyamat paramétereit."
                                       FontSize="14"
                                       Foreground="#7F8C8D"/>
                        </StackPanel>

                        <!-- Form Fields -->
                        <StackPanel Margin="0,0,0,24" >

                            <Expander Header="Optimalizációs paraméterek" IsExpanded="False" Foreground="{StaticResource TextLightBrush}"
                              Background="{StaticResource TransparentGreyBrush}"
                              Padding="8"
                              FontWeight="SemiBold"
                              Margin="0,10,0,10">

                                <StackPanel>
                                    <TextBlock Text="Populáció mérete"
                                                FontSize="13"
                                                FontWeight="Medium"
                                                Foreground="#2C3E50"
                                                Margin="0,0,0,4"/>
                                    <ui:NumberBox x:Uid="num_PopulationSize"
                                                  x:Name="num_PopulationSize"
                                                  SpinButtonPlacementMode="Compact" Value="100" Minimum="1"/>

                                    <TextBlock Text="Generációk száma"
                                                FontSize="13"
                                                FontWeight="Medium"
                                                Foreground="#2C3E50"
                                                Margin="0,10,0,4"/>
                                    <ui:NumberBox x:Uid="num_IterationNumber"
                                                  x:Name="num_IterationNumber"
                                                  SpinButtonPlacementMode="Compact" Value="150" Minimum="1"/>
                                </StackPanel>

                            </Expander>

                            <Expander Header="Egyed generálási paraméterek" IsExpanded="False" Foreground="{StaticResource TextLightBrush}"
                              Background="{StaticResource TransparentGreyBrush}"
                              Padding="8"
                              FontWeight="SemiBold"
                              Margin="0,0,0,10">
                                <StackPanel>

                                    <TextBlock Text="Útvonalak száma"
                                                FontSize="13"
                                                FontWeight="Medium"
                                                Foreground="#2C3E50"
                                                Margin="0,0,0,4"/>
                                    <ui:NumberBox x:Uid="num_Genome_RouteCount"
                                                  x:Name="num_Genome_RouteCount"
                                                  Value="30" Minimum="1" SpinButtonPlacementMode="Compact"/>

                                    <TextBlock Text="Csomópontok száma útvonalanként"
                                                FontSize="13"
                                                FontWeight="Medium"
                                                Foreground="#2C3E50"
                                                Margin="0,10,0,4"/>
                                    <ui:NumberBox x:Uid="num_Genome_HubCount"
                                                  x:Name="num_Genome_HubCount"
                                                   SpinButtonPlacementMode="Compact" Value="1" Minimum="1" />

                                    <CheckBox  x:Uid="num_Genome_AllowOneWay"
                                               x:Name="num_Genome_AllowOneWay"
                                                Content="Egyirányú útvonalak engedélyezése"
                                                FontSize="13"
                                                FontWeight="Medium"
                                                Foreground="#2C3E50"
                                                IsChecked="True"
                                                Margin="0,10,0,0"/>

                                </StackPanel>

                            </Expander>

                            <Expander Header="Célfüggvény paraméterek" IsExpanded="False" Foreground="{StaticResource TextLightBrush}"
                              Background="{StaticResource TransparentGreyBrush}"
                              Padding="8"
                              FontWeight="SemiBold"
                              Margin="0,0,0,10">

                                <StackPanel>

                                    <TextBlock Text="Megengedett redundancia (%)"
                                                FontSize="13"
                                                FontWeight="Medium"
                                                Foreground="#2C3E50"
                                                Margin="0,0,0,4"/>
                                    <ui:NumberBox x:Uid="num_Fitness_Redundacy"
                                                  x:Name="num_Fitness_Redundancy"
                                                  SpinButtonPlacementMode="Compact" Value="50" Minimum="0"/>

                                    <TextBlock Text="Járat hossz (megállószám)"
                                                FontSize="13"
                                                FontWeight="Medium"
                                                Foreground="#2C3E50"
                                                Margin="0,10,0,4"/>
                                    <ui:NumberBox x:Uid="num_Fitness_Length"
                                                  x:Name="num_Fitness_Length"
                                                  SpinButtonPlacementMode="Compact" Value="18" Minimum="0"/>

                                    <TextBlock Text="Maximális megengedett átszállás"
                                                FontSize="13"
                                                FontWeight="Medium"
                                                Foreground="#2C3E50"
                                                Margin="0,10,0,4"/>
                                    <ui:NumberBox x:Uid="num_Fitness_Changes"
                                                  x:Name="num_Fitness_Changes"
                                                  SpinButtonPlacementMode="Compact" Value="2" Minimum="0"/>

                                    <TextBlock Text="Flotta kapacitás"
                                                FontSize="13"
                                                FontWeight="Medium"
                                                Foreground="#2C3E50"
                                                Margin="0,10,0,4"/>
                                    <ui:NumberBox x:Uid="num_Fitness_Fleet"
                                                  x:Name="num_Fitness_Fleet"
                                                  SpinButtonPlacementMode="Compact" Value="100" Minimum="1"/>

                                    <TextBlock Text="Maximális várakozási idő (perc)"
                                                FontSize="13"
                                                FontWeight="Medium"
                                                Foreground="#2C3E50"
                                                Margin="0,10,0,4"/>
                                    <ui:NumberBox x:Uid="num_Fitness_MaxWait"
                                                  x:Name="num_Fitness_MaxWait"
                                                  SpinButtonPlacementMode="Compact" Value="30" Minimum="0"/>

                                    <TextBlock Text="Minimális várakozási idő (perc)"
                                                FontSize="13"
                                                FontWeight="Medium"
                                                Foreground="#2C3E50"
                                                Margin="0,10,0,4"/>
                                    <ui:NumberBox x:Uid="num_Fitness_MinWait"
                                                  x:Name="num_Fitness_MinWait"
                                                  SpinButtonPlacementMode="Compact" Value="5" Minimum="0"/>

                                    <TextBlock Text="Maximális utazási idő (perc)"
                                                FontSize="13"
                                                FontWeight="Medium"
                                                Foreground="#2C3E50"
                                                Margin="0,10,0,4"/>
                                    <ui:NumberBox x:Uid="num_Fitness_MaxTravelTime"
                                                  x:Name="num_Fitness_MaxTravelTime"
                                                  SpinButtonPlacementMode="Compact" Value="120" Minimum="1"/>

                                </StackPanel>

                            </Expander>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ==================== RIGHT PANEL (LOG) ==================== -->
        <Grid Grid.Column="1" Background="{StaticResource TransparentGreyBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border BorderBrush="#555" BorderThickness="0,0,0,1" Padding="16,8" Background="{StaticResource TransparentGreyBrush}" >
                <DockPanel>
                    <TextBlock Text="Optimalizációs napló"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextLightBrush}"
                               DockPanel.Dock="Left"/>
                    <Border Background="{StaticResource BackgroundLightBrush}" CornerRadius="5" Width="200" DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Uid="btn_Cancel"
                                x:Name="btn_Cancel"
                                Content="Mégse"
                                Style="{StaticResource GreyButton}"
                                Height="22"
                                Margin="0,0,15,0"
                                Click="btn_Cancel_Click"
                                />
                            
                            <StackPanel  Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse x:Uid="circle_GAstatus"
                                   x:Name="circle_GAstatus"
                                   Width="10" Height="10" Fill="{StaticResource TextLightBrush}" />
                                <TextBlock x:Uid="lbl_GAstatus"
                                   x:Name="lbl_GAstatus"
                                   Text="Standby"
                                   FontWeight="SemiBold"
                                   Margin="10,0,0,0"
                                   Foreground="{StaticResource TextLightBrush}"
                                   FontSize="12"/>
                            </StackPanel>
                        
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Log Entries -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
                <ItemsControl ItemsSource="{Binding Logs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontFamily="Consolas"
                           FontSize="12"
                           Margin="5"
                           TextWrapping="Wrap"
                           Text="{Binding FormattedMessage}"
                           Foreground="{Binding Level, Converter={StaticResource LogLevelToBrushConverter}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
